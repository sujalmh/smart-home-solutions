APP_NAME=room-automation-backend
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./room_automation.db
## Add your production frontend / API domain(s) to allow CORS from them
# For example:
# CORS_ORIGINS=https://api.sms.hebbit.tech,https://app.yourdomain.com
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# LLM provider config (choose one key)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Optional override. For OpenRouter use:
# OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini
AI_CONFIDENCE_THRESHOLD=0.65
AI_MEMORY_TTL_SECONDS=900
AI_HIGH_RISK_CONFIRMATION_REQUIRED=true
AI_RATE_LIMIT_PER_MINUTE=20
